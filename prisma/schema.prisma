generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Таблица для хранения текстов блоков (наш Inline Editor)
model StrankaObsah {
  id          Int      @id @default(autoincrement())
  stranka     String   // "domov"
  sekcia      String   @unique // "domov-o-nas"
  obsah       Json     // JSON со всеми текстами
  updatedAt   DateTime @updatedAt
}

// Таблица для продуктов (Коллекции)
model Produkt {
  id          Int      @id @default(autoincrement())
  tag         String   
  title       String   
  description String   
  mainImage   String   
  gallery     String[] 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Таблица для заявок от клиентов
model Objednavka {
  id        Int      @id @default(autoincrement())
  meno      String
  telefon   String
  email     String?
  sprava    String?
  status    String   @default("Nové") 
  createdAt DateTime @default(now())
}

model Collection {
  id          Int      @id @default(autoincrement())
  slug        String   @unique // Например: "moderne-linie" (для ссылки)
  title       String   // "MODERNÉ LÍNIE"
  subtitle    String   // "Minimalizmus. Čistá architektúra..."
  mainImage   String   // Ссылка на картинку
  description String   @db.Text // Тот длинный текст со скриншота
  features    Json?    // Список "Individuálne riešenie", "Dlhá životnosť" и т.д.
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String   // Название (например: "Betónový plot 2m")
  slug        String   @unique // Ссылка (betonovy-plot-2m)
  category    String   // Стиль (Moderné línie)
  description String   @db.Text // Описание проекта
  mainImage   String   // Главное фото для карточки
  images      String[] // Массив ссылок для галереи
  location    String?  // Город (Bratislava, Trnava...)
  createdAt   DateTime @default(now())
}